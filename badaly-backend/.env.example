# ╔══════════════════════════════════════════╗
# ║          BADALY · .env config           ║
# ║  Copy this to .env and fill in values  ║
# ╚══════════════════════════════════════════╝

PORT=3001

# ── Retell AI ──────────────────────────────
# Get from: https://app.retellai.com/dashboard
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Retell-provisioned "from" phone number (E.164 format)
# Buy one inside Retell dashboard → Phone Numbers → Buy number
RETELL_FROM_NUMBER=+12025550123

# ── Override company target numbers ────────
# Leave blank to use defaults in server.js
# Format: E.164 (+20xxxxxxxxxx)
NUM_VODAFONE=
NUM_WE=
NUM_ORANGE=
NUM_ETISALAT=
NUM_CIB=
NUM_NBE=
NUM_BANQUEMISR=
NUM_QNB=
NUM_BANQUEDUCAIRE=
